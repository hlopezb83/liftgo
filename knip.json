{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "index.html",
    "src/**/*.{test,spec}.{ts,tsx}",
    "src/test/**/*.{ts,tsx}",
    "tests/e2e/**/*.{ts,tsx}",
    "supabase/functions/**/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/integrations/supabase/**",
    "src/components/ui/**",
    "src/components/forms/fields/CustomerField.tsx",
    "src/components/forms/fields/DateRangeField.tsx",
    "src/components/forms/fields/ForkliftField.tsx",
    "src/features/suppliers/components/suppliers/SupplierSelector.tsx",
    "src/features/suppliers/lib/queryKeys.ts",
    "src/features/accounts-payable/hooks/useSupplierBills.ts",
    "src/lib/domain/errorCatalog.ts",
    "src/features/crm/lib/constants.ts",
    "src/components/feedback/CardListSkeleton.tsx",
    "src/components/feedback/FormSkeleton.tsx",
    "src/components/layout/DetailLayout.tsx",
    "src/components/layout/ListToolbar.tsx"
  ],
  "ignoreDependencies": [
    "tailwindcss",
    "@tailwindcss/typography",
    "tw-animate-css"
  ],
  "ignoreExportsUsedInFile": true
}
