{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.tsx",
    "index.html",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "src/**/*.{test,spec}.{ts,tsx}",
    "src/test/**/*.{ts,tsx}",
    "tests/e2e/**/*.{ts,tsx}",
    "supabase/functions/**/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/integrations/supabase/**",
    "src/components/ui/**"
  ],
  "ignoreDependencies": [
    "@types/node"
  ],
  "ignoreExportsUsedInFile": true
}
