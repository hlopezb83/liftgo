{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "index.html",
    "src/**/*.{test,spec}.{ts,tsx}",
    "src/test/**/*.{ts,tsx}",
    "tests/e2e/**/*.{ts,tsx}",
    "supabase/functions/**/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/integrations/supabase/**",
    "src/components/ui/**"
  ],
  "ignoreDependencies": [
    "@sentry/react",
    "@sentry/vite-plugin"
  ],
  "ignoreExportsUsedInFile": true
}
